  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortega26/GEO-skill.git"
  },
  "bugs": {
    "url": "https://github.com/cortega26/GEO-skill/issues"
  },
  "homepage": "https://github.com/cortega26/GEO-skill#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
