{
  "name": "geo-opt",
  "version": "2.0.0",
  "description": "Source-available Generative Engine Optimization audit and structured-data CLI",
  "main": "src/index.js",
  "bin": {
    "geo-opt": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md",
    "LICENSE-HISTORY.md",
    "LEGACY-MIT-LICENSE",
    "docs/"
  ],
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/ bin/",
