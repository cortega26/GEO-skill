    "format:check": "prettier --check src/ bin/ tests/",
    "check": "npm run lint && npm run format:check && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "geo",
    "seo",
    "rag",
